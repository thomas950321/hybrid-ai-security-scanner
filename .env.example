NODE_ENV=development
PORT=4000
NUCLEI_PATH=nuclei
SCANNER_ALLOWED_HOSTS=localhost,127.0.0.1,::1,host.docker.internal
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54322/postgres
# AI_BASE_URL 與 AI_API_KEY 依你使用的服務商而定。以下為 NVIDIA API 範例：
# AI_BASE_URL=https://integrate.api.nvidia.com/v1
# AI_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_BASE_URL=
AI_API_KEY=
EMBEDDING_MODEL=nvidia/nv-embed-qa-4
EXECUTOR_MODEL=minimaxai/minimax-m2.7

