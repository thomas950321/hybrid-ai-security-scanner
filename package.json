{
  "name": "hybrid-ai-security-scanner",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "dev:api": "pnpm --filter @hybrid/api dev",
    "dev:scout": "pnpm --filter @hybrid/scout-worker dev",
    "dev:analyst": "pnpm --filter @hybrid/analyst-worker dev",
    "dev:executor": "pnpm --filter @hybrid/executor-worker dev",
    "dev:indexer": "pnpm --filter @hybrid/indexer dev",
    "db:migrate": "pnpm --filter @hybrid/db migrate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "scan": "pnpm --filter @hybrid/scout-worker dev"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
